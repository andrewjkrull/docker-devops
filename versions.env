# ---------------------------------------------------------------------------
# versions.env — single source of truth for all tool versions
# Used by Makefile (passed as --build-arg to every docker build invocation)
# ---------------------------------------------------------------------------

# Python / Ansible  (ansible-core only — smaller than the community mega-package)
ANSIBLE_CORE_VERSION=2.17.10
ANSIBLE_LINT_VERSION=25.1.3

# Infrastructure as Code
# NOTE: Terraform and OpenTofu are functionally equivalent for this PoC.
#       Both are included in :full and :iac.  If you want to drop one,
#       comment it out here AND remove its ARG/RUN lines from the Dockerfiles.
TERRAFORM_VERSION=1.14.7
OPENTOFU_VERSION=1.9.1
PACKER_VERSION=1.15.0

# Secrets
VAULT_VERSION=1.21.4
SOPS_VERSION=3.10.2
AGE_VERSION=1.2.1

# Kubernetes
KUBECTL_VERSION=1.34.1
HELM_VERSION=3.19.0
KUSTOMIZE_VERSION=5.7.1
K3D_VERSION=5.7.5

# Security / Supply-chain
TRIVY_VERSION=0.69.3
GRYPE_VERSION=0.109.0
SYFT_VERSION=1.22.0
GITLEAKS_VERSION=8.28.0

# Utilities
YQ_VERSION=4.47.2

# Cloud CLIs
AWSCLI_VERSION=2.27.12
AZURECLI_VERSION=2.85.0

# Container tooling (docker-cli-source stage)
DOCKER_VERSION=27.5.1
